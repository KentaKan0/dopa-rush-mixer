<Window x:Class="DopaRushMixer.MainWindow" x:Name="MixerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Icon="Assets/DopaRushMixer.ico" Width="460" Height="860" MinWidth="360" MinHeight="520"
        Topmost="True" ShowInTaskbar="True" Background="#FF171717" Foreground="#FFE5E5E5"
        WindowStyle="None" ResizeMode="CanResizeWithGrip">
  <Window.Resources>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#FFB8B8B8" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="#FF292929" />
      <Setter Property="BorderBrush" Value="#FF474747" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="ChannelFader" TargetType="Slider">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid Margin="2,0">
              <Border Height="10" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" VerticalAlignment="Center" />
              <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}" IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="{x:Static Slider.DecreaseLarge}" CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" Opacity="0" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Width="10" Height="18" Background="#FFFFA24D" BorderBrush="#FF151515" BorderThickness="1" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="{x:Static Slider.IncreaseLarge}" CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" Opacity="0" />
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="LevelMeter" TargetType="ProgressBar">
      <Setter Property="Height" Value="10" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#FFFF6A00" />
    </Style>
    <Style x:Key="ChannelButton" TargetType="ToggleButton">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Foreground" Value="#FFD4D4D4" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Background" Value="#FF191919" />
      <Setter Property="BorderBrush" Value="#FF4B4B4B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True"><Setter TargetName="Surface" Property="Background" Value="#FFFF6A00" /><Setter Property="Foreground" Value="#FF161616" /></Trigger>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFA24D" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="30" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" Background="#FF2D2D2D" LastChildFill="True">
      <Button x:Name="ApplicationMenuButton" DockPanel.Dock="Left" Content="DOPA RUSH  ▾" MinWidth="116" FontSize="11" FontWeight="Bold" Background="#FF393939" BorderBrush="#FF555555" Click="ApplicationMenuClicked">
        <Button.ContextMenu>
          <ContextMenu>
            <MenuItem Header="更新" Click="RefreshClicked" />
            <MenuItem Header="常に手前" IsCheckable="True" IsChecked="True" Checked="TopmostChanged" Unchecked="TopmostChanged" />
            <Separator />
            <MenuItem Header="最小化" Click="MinimizeClicked" />
            <MenuItem Header="閉じる" Click="CloseClicked" />
          </ContextMenu>
        </Button.ContextMenu>
      </Button>
      <Border Background="#FF2D2D2D" MouseLeftButtonDown="HeaderMouseDown" ToolTip="ドラッグしてウィンドウを移動">
        <DockPanel LastChildFill="True">
          <TextBlock DockPanel.Dock="Right" Text="MIXER" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#FF8F8F8F" />
          <TextBlock Text="DRAG TO MOVE" FontSize="9" Foreground="#FF777777" VerticalAlignment="Center" Margin="10,0,0,0" />
        </DockPanel>
      </Border>
    </DockPanel>

    <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="6" Margin="0,6,0,6">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <TextBlock Text="AUDIO OUT" Style="{StaticResource SectionLabel}" Margin="0,0,0,3" />
        <ComboBox Grid.Row="1" ItemsSource="{Binding OutputDevices}" SelectedItem="{Binding SelectedOutputDevice, Mode=TwoWay}" DisplayMemberPath="Name" />
        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="0,5,0,0" DataContext="{Binding EndpointVolume}">
          <Grid Margin="5"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="20" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <Viewbox Width="16" Height="16" VerticalAlignment="Center"><Grid><Path Fill="#FFFFA24D" Data="M3,6 L7,6 L12,2 L12,14 L7,10 L3,10 Z" /><Path Stroke="#FFFFA24D" StrokeThickness="1.5" StrokeStartLineCap="Round" Data="M14,6 C16,7 16,9 14,10 M16,4 C20,7 20,9 16,12" /></Grid></Viewbox>
              <TextBlock Grid.Column="1" FontWeight="Bold" Foreground="#FFE5E5E5" TextTrimming="CharacterEllipsis"><Run Text="{Binding VolumeText, Mode=OneWay}" /><Run Text=": MASTER" /></TextBlock>
            </Grid>
            <Grid Grid.Row="1" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <Border Grid.Column="0" Height="10" Background="#FF111111" BorderBrush="#FF626262" BorderThickness="1" VerticalAlignment="Center" />
              <ProgressBar Grid.Column="0" Style="{StaticResource LevelMeter}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=OneWay}" Foreground="#FF626262" />
              <ProgressBar Grid.Column="0" Style="{StaticResource LevelMeter}" Minimum="0" Maximum="100" Value="{Binding PeakPercent, Mode=OneWay}" Foreground="#FFFF6A00" />
              <Slider Grid.Column="0" Style="{StaticResource ChannelFader}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}" ValueChanged="MasterVolumeChanged" PreviewMouseLeftButtonDown="InteractionStarted" PreviewMouseLeftButtonUp="InteractionEnded" LostMouseCapture="InteractionCaptureLost" PreviewMouseWheel="FaderMouseWheel" ToolTip="{Binding VolumeText}" />
              <ToggleButton Grid.Column="1" Style="{StaticResource ChannelButton}" Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" Checked="MasterMuteChanged" Unchecked="MasterMuteChanged" Margin="5,0,0,0" />
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Expander Grid.Row="2" Margin="0,0,0,8">
      <Expander.Header>
        <TextBlock FontWeight="SemiBold"><Run Text="VIVALDI TAB DETECTION  " /><Run Text="(" /><Run Text="{Binding DetectedBrowserTabCount, Mode=OneWay}" /><Run Text=")" /></TextBlock>
      </Expander.Header>
      <Border Style="{StaticResource PanelBorder}" Padding="8" Margin="0,6,0,0" MaxHeight="100">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding DetectedBrowserTabs}">
            <ItemsControl.ItemTemplate><DataTemplate><StackPanel Margin="2,2,2,6"><TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding Instruction}" FontSize="11" Foreground="#FFAFAFAF" /></StackPanel></DataTemplate></ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </Expander>

    <DockPanel Grid.Row="3" Margin="0,0,0,5">
      <TextBlock Text="CHANNEL STRIPS" Style="{StaticResource SectionLabel}" />
      <TextBlock Text="HORIZONTAL MIXER" Style="{StaticResource SectionLabel}" Foreground="#FF777777" HorizontalAlignment="Right" />
    </DockPanel>

    <Border Grid.Row="4" Background="#FF202020" BorderBrush="#FF414141" BorderThickness="1">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="8">
        <StackPanel>
          <Border Style="{StaticResource PanelBorder}" Padding="5" Margin="0,0,0,7">
            <StackPanel>
              <TextBlock Text="VIVALDI" Style="{StaticResource SectionLabel}" Foreground="#FFB8B8B8" Margin="1,0,0,4" />
              <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,3" DataContext="{Binding VivaldiMaster}">
                <Grid Margin="5"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="20" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Image Source="{Binding DataContext.VivaldiIcon, ElementName=MixerWindow}" Width="16" Height="16" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                    <TextBlock Grid.Column="1" FontWeight="Bold" Foreground="#FFE5E5E5" TextTrimming="CharacterEllipsis"><Run Text="{Binding VolumeText, Mode=OneWay}" /><Run Text=": MASTER" /></TextBlock>
                  </Grid>
                  <Grid Grid.Row="1" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="10" Background="#FF111111" BorderBrush="#FF626262" BorderThickness="1" VerticalAlignment="Center" />
                    <ProgressBar Grid.Column="0" Style="{StaticResource LevelMeter}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=OneWay}" Foreground="#FF626262" />
                    <ProgressBar Grid.Column="0" Style="{StaticResource LevelMeter}" Minimum="0" Maximum="100" Value="{Binding PeakPercent, Mode=OneWay}" Foreground="#FFFF6A00" />
                    <Slider Grid.Column="0" Style="{StaticResource ChannelFader}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}" ValueChanged="VivaldiMasterVolumeChanged" PreviewMouseLeftButtonDown="InteractionStarted" PreviewMouseLeftButtonUp="InteractionEnded" LostMouseCapture="InteractionCaptureLost" PreviewMouseWheel="FaderMouseWheel" ToolTip="{Binding VolumeText}" />
                    <ToggleButton Grid.Column="1" Style="{StaticResource ChannelButton}" Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" Checked="VivaldiMasterMuteChanged" Unchecked="VivaldiMasterMuteChanged" Margin="5,0,0,0" />
                  </Grid>
                </Grid>
              </Border>
              <ItemsControl ItemsSource="{Binding BrowserTabs}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate><DataTemplate>
                  <Border Style="{StaticResource PanelBorder}" Margin="12,0,0,3">
                    <Grid Margin="5"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                      <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="20" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                          <Image Source="{Binding DataContext.VivaldiIcon, ElementName=MixerWindow}" Stretch="Uniform" SnapsToDevicePixels="True" />
                          <Image Source="{Binding FavIconUri}" Stretch="Uniform" SnapsToDevicePixels="True" />
                        </Grid>
                        <TextBlock Grid.Column="1" FontWeight="Bold" FontSize="11" TextTrimming="CharacterEllipsis"><Run Text="{Binding VolumeText, Mode=OneWay}" /><Run Text=": " /><Run Text="{Binding Title, Mode=OneWay}" /></TextBlock>
                      </Grid>
                      <Grid Grid.Row="1" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="10" Background="#FF111111" BorderBrush="#FF626262" BorderThickness="1" VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="0" Style="{StaticResource LevelMeter}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=OneWay}" Foreground="#FFFF6A00" />
                        <Slider Grid.Column="0" Style="{StaticResource ChannelFader}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}" ValueChanged="BrowserVolumeChanged" PreviewMouseLeftButtonDown="InteractionStarted" PreviewMouseLeftButtonUp="InteractionEnded" LostMouseCapture="InteractionCaptureLost" PreviewMouseWheel="FaderMouseWheel" ToolTip="{Binding VolumeText}" />
                        <ToggleButton Grid.Column="1" Style="{StaticResource ChannelButton}" Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" Checked="BrowserMuteChanged" Unchecked="BrowserMuteChanged" Margin="5,0,0,0" />
                        <Button Grid.Column="2" Content="×" Width="24" Height="20" Padding="0" Click="RemoveBrowserTabClicked" ToolTip="タブ音量制御を解除" />
                      </Grid>
                    </Grid>
                  </Border>
                </DataTemplate></ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
          <ItemsControl ItemsSource="{Binding Sessions}">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate><DataTemplate>
              <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,4">
                <Grid Margin="5"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="20" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Image Source="{Binding AppIcon}" Width="16" Height="16" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                    <TextBlock Grid.Column="1" FontWeight="Bold" TextTrimming="CharacterEllipsis"><Run Text="{Binding VolumeText, Mode=OneWay}" /><Run Text=": " /><Run Text="{Binding Name, Mode=OneWay}" /></TextBlock>
                  </Grid>
                  <Grid Grid.Row="1" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="10" Background="#FF111111" BorderBrush="#FF626262" BorderThickness="1" VerticalAlignment="Center" />
                    <ProgressBar Grid.Column="0" Style="{StaticResource LevelMeter}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=OneWay}" Foreground="#FF626262" />
                    <ProgressBar Grid.Column="0" Style="{StaticResource LevelMeter}" Minimum="0" Maximum="100" Value="{Binding PeakPercent, Mode=OneWay}" Foreground="#FFFF6A00" />
                    <Slider Grid.Column="0" Style="{StaticResource ChannelFader}" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}" ValueChanged="VolumeChanged" PreviewMouseLeftButtonDown="InteractionStarted" PreviewMouseLeftButtonUp="InteractionEnded" LostMouseCapture="InteractionCaptureLost" PreviewMouseWheel="FaderMouseWheel" ToolTip="{Binding VolumeText}" />
                    <ToggleButton Grid.Column="1" Style="{StaticResource ChannelButton}" Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" Checked="MuteChanged" Unchecked="MuteChanged" Margin="5,0,0,0" />
                    <Button Grid.Column="2" Content="×" Width="24" Height="20" Padding="0" Click="RemoveSessionClicked" ToolTip="チャンネルを一覧から削除" />
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate></ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="再生中のアプリはありません。" Foreground="#FF999999" VerticalAlignment="Center" Margin="8,0,0,0">
            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasSessions}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
