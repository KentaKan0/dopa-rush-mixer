<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <AssemblyName>DopaRushMixer</AssemblyName>
    <Product>DopaRush Mixer</Product>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableDefaultPageItems>false</EnableDefaultPageItems>
    <ApplicationManifest>src\app.manifest</ApplicationManifest>
    <ApplicationIcon>src\Assets\DopaRushMixer.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <ApplicationDefinition Include="src\App.xaml" />
    <Page Include="src\MainWindow.xaml" />
    <Resource Include="src\Assets\DopaRushMixer.ico" />
  </ItemGroup>
</Project>
